{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Desktop Reminder",
  "version": "0.1.1",
  "identifier": "com.desktop.reminder",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "editor",
        "title": "Desktop Reminder Editor",
        "url": "index.html?view=editor",
        "width": 1160,
        "height": 860,
        "minWidth": 960,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "floating",
        "title": "Desktop Reminder",
        "url": "index.html?view=floating",
        "width": 388,
        "height": 360,
        "minWidth": 320,
        "minHeight": 280,
        "resizable": false,
        "fullscreen": false,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": false,
        "alwaysOnBottom": false,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
